#!/bin/bash

set -eufo pipefail

# =============================================================================
# Nix: declarative CLI tools via flake.nix
# =============================================================================

echo "==> Installing Nix packages..."

if ! command -v nix &>/dev/null; then
    echo "Nix is not installed. Installing via Determinate Systems installer..."
    curl --proto '=https' --tlsv1.2 -sSf -L https://install.determinate.systems/nix | sh -s -- install --no-confirm

    if [ -e '/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh' ]; then
        . '/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh'
    fi
fi

CHEZMOI_SOURCE="{{ .chezmoi.sourceDir }}"
# `add` is the modern spelling of the deprecated `install`. If the flake is
# already in the profile, upgrade it instead of re-adding (avoids the
# "already added" warning and picks up flake.nix changes on re-run).
if nix profile list 2>/dev/null | grep -q "path:${CHEZMOI_SOURCE}"; then
    echo "Upgrading CLI tools from flake at $CHEZMOI_SOURCE..."
    nix profile upgrade --all
else
    echo "Installing CLI tools from flake at $CHEZMOI_SOURCE..."
    nix profile add "path:${CHEZMOI_SOURCE}"
fi

# =============================================================================
# Optional package picker (interactive y/n via gum; choices are remembered)
# =============================================================================
#
# Core tools above are ALWAYS installed. Everything below is opt-in: a styled
# gum checklist lets you pick which to install. The choice is saved so re-runs
# and other machines are reproducible; with no TTY (CI) the saved/default set is
# used. Env knobs: DOTFILES_NONINTERACTIVE=1 (skip prompt), DOTFILES_RESELECT=1
# (ignore saved choice, start from defaults), DRY_RUN=1 (print, don't install).
#
# Manifest of OPTIONAL components.  format: key|label|method|default|target
#   method: cask | formula | nix | npm
optional_items=(
    "aerospace|AeroSpace (tiling window manager)|cask|on|nikitabobko/tap/aerospace"
    "obsidian|Obsidian (Markdown notes)|cask|on|obsidian"
    "claude-code|Claude Code (AI coding CLI)|cask|on|claude-code"
    "borders|JankyBorders (window borders)|formula|on|borders"
    "sketchybar|SketchyBar (status bar)|formula|on|sketchybar"
    "bat|bat (cat with syntax highlight)|nix|off|bat"
    "htop|htop (process viewer)|nix|off|htop"
    # Example — needs Node.js: add `nodejs_24` to flake.nix core, then uncomment:
    # "openclaw|OpenClaw (self-hosted AI assistant)|npm|off|openclaw@latest"
)

field() { printf '%s' "$1" | cut -d'|' -f"$2"; }

run() {
    if [ -n "${DRY_RUN:-}" ]; then echo "DRY: $*"; else "$@"; fi
}

SEL_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/dotfiles/packages.selected"
mkdir -p "$(dirname "$SEL_FILE")"

# Pre-selected set: saved file if present (and not resetting), else manifest defaults.
PRESELECTED=""
if [ -f "$SEL_FILE" ] && [ -s "$SEL_FILE" ] && [ "${DOTFILES_RESELECT:-0}" != "1" ]; then
    PRESELECTED=$(tr '\n' ',' < "$SEL_FILE" | sed 's/,$//')
else
    for item in "${optional_items[@]}"; do
        [ "$(field "$item" 4)" = "on" ] && PRESELECTED="${PRESELECTED:+$PRESELECTED,}$(field "$item" 1)"
    done
fi

ALL_KEYS=()
for item in "${optional_items[@]}"; do
    ALL_KEYS+=( "$(field "$item" 1)" )
done

# Resolve gum: use it if installed, else run it ephemerally via Nix (no install).
GUM=""
if command -v gum &>/dev/null; then
    GUM="gum"
elif command -v nix &>/dev/null; then
    GUM="nix run nixpkgs#gum --"
fi

SELECTED_CSV="$PRESELECTED"
if [ -n "$GUM" ] && [ -t 0 ] && [ -t 1 ] && [ "${DOTFILES_NONINTERACTIVE:-0}" != "1" ]; then
    echo "==> Optional packages (core tools are always installed):"
    for item in "${optional_items[@]}"; do
        printf '    %-13s %s\n' "$(field "$item" 1)" "$(field "$item" 2)"
    done
    set +e
    picked=$(printf '%s\n' "${ALL_KEYS[@]}" | $GUM choose --no-limit \
        --header "Select optional packages — space toggles, enter confirms" \
        --selected "$PRESELECTED")
    rc=$?
    set -e
    if [ "$rc" -eq 0 ]; then
        SELECTED_CSV=$(printf '%s' "$picked" | tr '\n' ',' | sed 's/,$//')
    else
        echo "    (selection cancelled — keeping previous/default set)"
    fi
fi

# Persist the chosen set (one key per line) for reproducible re-runs.
printf '%s\n' "$SELECTED_CSV" | tr ',' '\n' | sed '/^$/d' > "$SEL_FILE"
echo "==> Optional set: ${SELECTED_CSV:-<none>}"

is_selected() {
    case ",${SELECTED_CSV}," in
        *",$1,"*) return 0 ;;
        *) return 1 ;;
    esac
}

# --- Optional NIX packages (any OS) ------------------------------------------
for item in "${optional_items[@]}"; do
    [ "$(field "$item" 3)" = "nix" ] || continue
    key=$(field "$item" 1); target=$(field "$item" 5)
    is_selected "$key" || continue
    if nix profile list 2>/dev/null | grep -qF "${CHEZMOI_SOURCE}#${target}"; then
        echo "$key (nix) already installed"
    else
        echo "Installing $key (nix)..."
        run nix profile add "path:${CHEZMOI_SOURCE}#${target}" || echo "Warning: failed to install $key, continuing..."
    fi
done

# =============================================================================
# Homebrew: macOS GUI apps and platform-specific formulae
# =============================================================================

{{ if eq .chezmoi.os "darwin" -}}
echo "==> Installing Homebrew packages (macOS)..."

if ! command -v brew &>/dev/null; then
    echo "Homebrew is not installed. Installing..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

run brew update

install_cask() {
    local target="$1" name
    name=$(basename "$target")
    if brew list --cask "$name" &>/dev/null; then
        echo "$name is already installed"
    elif [ -n "${DRY_RUN:-}" ]; then
        echo "DRY: brew install --cask $target"
    else
        echo "Installing cask $target..."
        if ! brew install --cask "$target" 2>/dev/null; then
            if brew list --cask "$name" &>/dev/null; then
                echo "$name is now installed"
            else
                echo "Warning: Failed to install $name, but continuing..."
            fi
        fi
    fi
}

install_formula() {
    local target="$1"
    if brew list "$target" &>/dev/null; then
        echo "$target is already installed"
    else
        echo "Installing formula $target..."
        run brew install "$target" || echo "Warning: Failed to install $target, but continuing..."
    fi
}

install_npm() {
    local target="$1"
    if ! command -v npm &>/dev/null; then
        echo "Warning: $target needs Node.js/npm (not installed). Skipping."
        return 0
    fi
    echo "Installing npm global $target..."
    run npm install -g "$target" || echo "Warning: Failed to install $target, but continuing..."
}

# Core casks — always installed.
for cask in kitty ghostty; do
    install_cask "$cask"
done

# Optional casks / formulae / npm from the picker.
felix_tapped=0
for item in "${optional_items[@]}"; do
    key=$(field "$item" 1); method=$(field "$item" 3); target=$(field "$item" 5)
    is_selected "$key" || continue
    case "$method" in
        cask) install_cask "$target" ;;
        formula)
            if [ "$felix_tapped" -eq 0 ]; then
                brew tap | grep -q "FelixKratz/formulae" || run brew tap FelixKratz/formulae
                felix_tapped=1
            fi
            install_formula "$target" ;;
        npm) install_npm "$target" ;;
        nix) : ;; # handled above (cross-platform)
    esac
done
{{ end -}}

echo "==> All packages installed successfully!"
