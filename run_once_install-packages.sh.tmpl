#!/bin/bash

set -eufo pipefail

# =============================================================================
# Nix: declarative CLI tools via flake.nix
# =============================================================================

echo "==> Installing Nix packages..."

if ! command -v nix &>/dev/null; then
    echo "Nix is not installed. Installing via Determinate Systems installer..."
    curl --proto '=https' --tlsv1.2 -sSf -L https://install.determinate.systems/nix | sh -s -- install --no-confirm

    if [ -e '/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh' ]; then
        . '/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh'
    fi
fi

CHEZMOI_SOURCE="{{ .chezmoi.sourceDir }}"
echo "Installing CLI tools from flake at $CHEZMOI_SOURCE..."
nix profile install "path:${CHEZMOI_SOURCE}"

# =============================================================================
# Homebrew: macOS GUI apps and platform-specific formulae
# =============================================================================

{{ if eq .chezmoi.os "darwin" -}}
echo "==> Installing Homebrew packages (macOS GUI apps)..."

if ! command -v brew &>/dev/null; then
    echo "Homebrew is not installed. Installing..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

brew update

casks=(
    "nikitabobko/tap/aerospace"
    "kitty"
    "ghostty"
    "obsidian"
    "claude-code"
)

for cask in "${casks[@]}"; do
    cask_name=$(basename "$cask")
    if brew list --cask "$cask_name" &>/dev/null; then
        echo "$cask_name is already installed"
    else
        echo "Installing $cask..."
        if ! brew install --cask "$cask" 2>/dev/null; then
            if brew list --cask "$cask_name" &>/dev/null; then
                echo "$cask_name is now installed"
            else
                echo "Warning: Failed to install $cask_name, but continuing..."
            fi
        fi
    fi
done

if ! brew tap | grep -q "FelixKratz/formulae"; then
    brew tap FelixKratz/formulae
fi

felixkratz_packages=(
    "borders"
    "sketchybar"
)

for package in "${felixkratz_packages[@]}"; do
    if brew list "$package" &>/dev/null; then
        echo "$package is already installed"
    else
        echo "Installing $package..."
        brew install "$package"
    fi
done
{{ end -}}

echo "==> All packages installed successfully!"
